# AgentAlpha v6 Hybrid Live Demo — environment template
# Copy to `.env.local` and fill real values locally.
# NEVER commit private keys, wallet secrets, seed phrases, or funded-wallet secrets.

# =============================================================================
# v6 SCOPE LOCK
# =============================================================================
# v6 demo rule: only the Base-wide indexer is mocked.
# Payment and swap proof must be real wallet-confirmed Base transactions.
INDEXER_MODE=mock

# =============================================================================
# Base network profile
# v6 live demo target is Base Mainnet. Base Sepolia vars are kept for legacy/dev
# compatibility, but AC-04/AC-07/AC-08 live criteria are Base Mainnet evidence.
# =============================================================================
BASE_NETWORK=base-mainnet
NEXT_PUBLIC_BASE_NETWORK=base-mainnet

# Active RPC used by the verifier. Leave BASE_RPC_URL empty to use code default.
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_MAINNET_RPC_URL=https://mainnet.base.org

# Base Mainnet chain/token defaults used by v6 verifier/payment adapters.
BASE_CHAIN_ID=8453
BASE_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Optional explorer override. If empty, app uses https://basescan.org/tx/<hash>.
NEXT_PUBLIC_BASE_EXPLORER_TX_BASE_URL=

# =============================================================================
# Demo safety caps
# Server validation rejects unsafe mainnet demo values.
# =============================================================================
DEMO_MAX_SIGNAL_PRICE_USDC=1
DEMO_MAX_SWAP_USDC=1
PANCAKESWAP_SLIPPAGE_BPS=100

# =============================================================================
# Live payment / swap feature flags
# =============================================================================
NEXT_PUBLIC_ENABLE_REAL_PAYMENTS=true
NEXT_PUBLIC_ENABLE_REAL_SWAPS=true

# =============================================================================
# Flock.io — onboarding risk/style classification
# v6 behavior: call Flock first when FLOCK_API_KEY exists; otherwise persist
# classificationSource=fallback with deterministic fallback.
# =============================================================================
FLOCK_API_KEY=
FLOCK_API_BASE_URL=https://api.flock.io/v1
FLOCK_MODEL=qwen3-30b-a3b-instruct-2507
FLOCK_CLASSIFY_TIMEOUT_MS=8000
FLOCK_FALLBACK_MODE=rule_based
FLOCK_REQUIRE_LIVE_FOR_DEMO=false

# =============================================================================
# Coinbase AgentKit / CDP
# Kept from previous project env for compatibility/documentation.
# Current v6 MVP does NOT use CDP for core payment/swap execution because:
# - hard requirement says do not store user private keys client/server-side;
# - swaps must not auto-submit without user wallet confirmation;
# - current implementation uses browser wallet confirmation + PancakeSwap deep link.
# Future safe use: wallet provisioning/balance read helpers or explicit user-approved
# AgentKit flows, not unattended server-side trading.
# =============================================================================
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_SECRET=
# Compatibility aliases for older CDP env naming, if needed later.
# CDP_API_KEY_NAME=
# CDP_API_KEY_PRIVATE_KEY=

# =============================================================================
# x402
# Current v6 MVP uses real Base USDC transfer fallback and does not fake x402.
# EVM_PRIVATE_KEY is intentionally NOT consumed by current code to avoid server-side
# signing of user payments. Only wire this after a reviewed x402 facilitator flow.
# =============================================================================
EVM_PRIVATE_KEY=
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_PAYMENT_TOKEN=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
X402_RECEIVER_ADDRESS=

# =============================================================================
# Alchemy
# Kept from previous project env as a legacy/live-fallback placeholder.
# Current v6 scope explicitly forbids Base-wide/Alchemy indexing. Do not add
# Alchemy polling/webhook/indexer routes for the demo.
# =============================================================================
ALCHEMY_API_KEY=
ALCHEMY_BASE_SEPOLIA_URL=https://base-sepolia.g.alchemy.com/v2/
ALCHEMY_BASE_MAINNET_URL=https://base-mainnet.g.alchemy.com/v2/

# =============================================================================
# Platform wallet / revenue distribution
# PLATFORM_WALLET_ADDRESS is required for live payment receiver verification and
# revenue proof verification. PLATFORM_WALLET_PRIVATE_KEY is legacy/optional and
# intentionally not consumed by current code; do not store funded private keys in app env.
# =============================================================================
PLATFORM_WALLET_PRIVATE_KEY=
PLATFORM_WALLET_ADDRESS=
SELLER_REVENUE_SHARE=0.8

# =============================================================================
# Local ledger/runtime
# =============================================================================
AGENTALPHA_LEDGER_PATH=.data/ledger.json

# Test-only verifier bypass. Never enable outside test mode; production code rejects
# this unless NODE_ENV/VITEST indicates a test environment.
AGENTALPHA_MOCK_TX_VERIFIER=false
