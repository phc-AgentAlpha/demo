# AgentAlpha v6 Hybrid Live Demo — environment template
# Copy to `.env.local` and fill real values locally.
# NEVER commit private keys, wallet secrets, seed phrases, or funded-wallet secrets.

# =============================================================================
# v6 SCOPE LOCK
# =============================================================================
# v6 demo rule: only the Base-wide indexer is mocked.
# Payment and swap proof must be real Base transactions.
INDEXER_MODE=mock

# =============================================================================
# Base network profile
# Switch networks by changing BASE_NETWORK and NEXT_PUBLIC_BASE_NETWORK together.
# Supported values: base-mainnet, base-sepolia. Leave active chain/token overrides
# blank unless you intentionally need a custom RPC/token for the selected profile.
# =============================================================================
BASE_NETWORK=base-mainnet
NEXT_PUBLIC_BASE_NETWORK=base-mainnet

# Active RPC override. If blank, the selected profile uses the network-specific
# RPC below, then the official Base public default.
BASE_RPC_URL=
NEXT_PUBLIC_BASE_RPC_URL=
BASE_MAINNET_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Optional consistency guard. If set, it must match BASE_NETWORK.
# Base Mainnet: 8453 / 0x2105, Base Sepolia: 84532 / 0x14a34.
BASE_CHAIN_ID=
NEXT_PUBLIC_BASE_CHAIN_ID=

# Active USDC override. Leave blank to use profile defaults:
# Base Mainnet USDC: 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# Base Sepolia USDC: 0x036CbD53842c5426634e7929541eC2318f3dCF7e
BASE_USDC_ADDRESS=
NEXT_PUBLIC_BASE_USDC_ADDRESS=
BASE_MAINNET_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
BASE_SEPOLIA_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# Optional token overrides for profile gaps. AERO has a mainnet default; set a
# Base Sepolia address only if you have a real testnet token/liquidity target.
BASE_AERO_ADDRESS=
NEXT_PUBLIC_BASE_AERO_ADDRESS=
BASE_SEPOLIA_AERO_ADDRESS=
NEXT_PUBLIC_BASE_SEPOLIA_AERO_ADDRESS=

# Optional explorer override. Defaults to BaseScan for the selected network.
NEXT_PUBLIC_BASE_EXPLORER_BASE_URL=
NEXT_PUBLIC_BASE_EXPLORER_TX_BASE_URL=
NEXT_PUBLIC_BASE_EXPLORER_ADDRESS_BASE_URL=

# Optional PancakeSwap chain param override. Mainnet defaults to `base`; Sepolia
# defaults to `base-sepolia` and still requires manual-live liquidity validation.
PANCAKESWAP_CHAIN=
NEXT_PUBLIC_PANCAKESWAP_CHAIN=

# =============================================================================
# Demo safety caps
# Server validation rejects unsafe mainnet demo values.
# =============================================================================
DEMO_MAX_SIGNAL_PRICE_USDC=1
DEMO_MAX_SWAP_USDC=1
DEMO_MAX_DAILY_AGENT_BUDGET_USDC=5
PANCAKESWAP_SLIPPAGE_BPS=100

# =============================================================================
# Live payment / swap feature flags
# =============================================================================
NEXT_PUBLIC_ENABLE_REAL_PAYMENTS=true
NEXT_PUBLIC_ENABLE_REAL_SWAPS=true

# =============================================================================
# Flock.io — onboarding risk/style classification
# v6 behavior: call Flock first when FLOCK_API_KEY exists; otherwise persist
# classificationSource=fallback with deterministic fallback.
# =============================================================================
FLOCK_API_KEY=
FLOCK_API_BASE_URL=https://api.flock.io/v1
FLOCK_MODEL=qwen3-30b-a3b-instruct-2507
FLOCK_CLASSIFY_TIMEOUT_MS=8000
FLOCK_FALLBACK_MODE=rule_based
FLOCK_REQUIRE_LIVE_FOR_DEMO=false

# =============================================================================
# Coinbase CDP / Agent wallet
# Onboarding issues an Agent/AA wallet. Default `mock` keeps local/dev deterministic
# without storing keys. Set `cdp` for a live CDP smart-account wallet when these
# credentials are present. Private keys are never imported/exported by the app.
# =============================================================================
CDP_AGENT_WALLET_MODE=mock
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_SECRET=
# Compatibility aliases for older CDP env naming, if needed later.
# CDP_API_KEY_NAME=
# CDP_API_KEY_PRIVATE_KEY=

# =============================================================================
# x402
# Signal purchase is modeled as an agent-executed x402 exact payment. The app
# creates/verifies x402 payment requirements and only unlocks after a real Base
# settlement tx hash is verified. EVM_PRIVATE_KEY is legacy and intentionally not
# consumed; the buyer signer should be the Agent/AA wallet via CDP/x402 tooling.
#
# X402_RECEIVER_ADDRESS is the public address that receives payment. If empty,
# the app falls back to PLATFORM_WALLET_ADDRESS.
# =============================================================================
EVM_PRIVATE_KEY=
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_SEPOLIA_FACILITATOR_URL=https://x402.org/facilitator
X402_MAINNET_FACILITATOR_URL=
# Optional consistency guard. Leave blank to use selected profile (`eip155:8453` or `eip155:84532`).
X402_NETWORK=
X402_PAYMENT_TOKEN=
X402_RECEIVER_ADDRESS=
X402_RESOURCE_BASE_URL=http://localhost:3000

# =============================================================================
# Alchemy
# Kept from previous project env as a legacy/live-fallback placeholder.
# Current v6 scope explicitly forbids Base-wide/Alchemy indexing. Do not add
# Alchemy polling/webhook/indexer routes for the demo.
# =============================================================================
ALCHEMY_API_KEY=
ALCHEMY_BASE_SEPOLIA_URL=https://base-sepolia.g.alchemy.com/v2/
ALCHEMY_BASE_MAINNET_URL=https://base-mainnet.g.alchemy.com/v2/

# =============================================================================
# Platform wallet / revenue distribution
# PLATFORM_WALLET_ADDRESS is a public receiving address. It is required for live
# payment receiver verification and revenue proof verification. Current v6 MVP
# intentionally does not consume a platform wallet private key.
# =============================================================================
PLATFORM_WALLET_ADDRESS=
SELLER_REVENUE_SHARE=0.8

# =============================================================================
# Local ledger/runtime
# =============================================================================
AGENTALPHA_LEDGER_PATH=.data/ledger.json

# Test-only verifier bypass. Never enable outside test mode; production code rejects
# this unless NODE_ENV/VITEST indicates a test environment.
AGENT_SCAN_INTERVAL_MS=300000
AGENTALPHA_MOCK_TX_VERIFIER=false
